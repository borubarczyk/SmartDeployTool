{
  "DefaultInstallSource": "network",
  "InstallSourcePaths": {
    "network": "\\\\MARS\\installer\\",
    "web": "https://apps.ebkk.pl/Data/"
  },
  "CustomWebDataLocation": {
    "URL": "https://apps.ebkk.pl/Data/CustomWebData/"
  },
  "DomainJoin": {
    "DomainName": "home.local",
    "Username": "ad\\administrator"
  },
  "LocalAdmin": {
    "Username": "adm_local"
  },
  "SystemSettings": {
    "DisableDeliveryOptimization": true,
    "EnableWin10StartMenu": true,
    "DisableTelemetry": true,
    "DisableCortana": true,
    "DisableFastStartup": true,
    "DisableNewsAndInterests": true
  },
  "WebAuth": {
    "Username": "admin",
    "Password": "admin@123"
  },
  "TeamViewer": {
    "FileName": "TeamViewer_Host.msi",
    "Arguments": "/qn CUSTOMCONFIGID=62h5mt2 APITOKEN=8158247-example ASSIGNMENTOPTIONS=\"--alias %COMPUTERNAME% --grant-easy-access\""
  },
  "AntyVirus": {
    "DefaultInstallSource": "network",
    "InstallSourcePaths": {
      "network": "\\\\MARS\\installer\\antivirus\\",
      "web": "https://apps.ebkk.pl/Data/antivirus/"
    },
    "Credentials": {
      "Username": "admin",
      "Password": "admin@123"
    },
    "FileName": "AntyVirus.exe"
  },
  "WiFiProfile": {
    "FileName": "WiFiProfile.xml"
  },
  "Programs": {
    "Chrome": {
      "Enabled": true,
      "FileName": "ChromeSetup.exe",
      "SilentArgs": "/silent /install"
    },
    "7zip": {
      "Enabled": true,
      "FileName": "7z.exe",
      "SilentArgs": "/S"
    },
    "VLC": {
